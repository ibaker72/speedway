# ====================================
# Speedway Motors LLC — Environment Variables
# ====================================

# Inventory Source: "local" | "feed" | "aggregator"
INVENTORY_SOURCE=local

# Dealer Feed (if using feed source)
DEALER_FEED_URL=
DEALER_FEED_API_KEY=

# Analytics — Google Analytics 4
NEXT_PUBLIC_GA_ID=

# Analytics — Facebook Pixel
NEXT_PUBLIC_FB_PIXEL_ID=

# Analytics — Google Tag Manager
NEXT_PUBLIC_GTM_ID=

# Site URL (used for sitemap, canonical URLs, OG tags)
NEXT_PUBLIC_SITE_URL=https://www.speedwaymotorsllc.com
